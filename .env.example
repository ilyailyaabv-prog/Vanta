# ─────────────────────────────────────────────
# Vanta — Environment Variables Template
# Copy this file to .env.local and fill in values
# ─────────────────────────────────────────────

# Database
DATABASE_URL="postgresql://user:password@localhost:5432/vanta_dev"

# NextAuth
AUTH_SECRET="generate-a-random-secret-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Cloudflare R2 (Media Storage)
R2_ACCOUNT_ID="your-account-id"
R2_ACCESS_KEY_ID="your-access-key"
R2_SECRET_ACCESS_KEY="your-secret-key"
R2_BUCKET_NAME="vanta-dev"
R2_PUBLIC_URL="https://pub-xxxxx.r2.dev"

# Redis (Cache & Session Store)
REDIS_URL="redis://localhost:6379"

# Stripe (Payments)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# Sentry (Error Tracking)
SENTRY_DSN="https://xxx@sentry.io/xxx"
SENTRY_ENVIRONMENT="development"

# Email (SendGrid / AWS SES)
EMAIL_FROM="noreply@vanta.com"
SENDGRID_API_KEY="SG.xxx"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="Vanta"
NEXT_PUBLIC_DEFAULT_THEME="dark"